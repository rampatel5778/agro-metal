---
/**
 * Radio — accessible radio button with ds-radio styling
 * @example
 * <Radio id="plan-a" groupName="plan" name="plan" value="a" label="Plan A" />
 */
import type { RadioProps } from '@types/components/forms.js';
import { cn } from '@utils/classNames.js';

const {
  id,
  name,
  label,
  value,
  groupName,
  required = false,
  error,
  hint,
  checked = false,
  disabled = false,
  class: className = '',
} = Astro.props as RadioProps;

const describedBy = [hint && `${id}-hint`, error && `${id}-error`].filter(Boolean).join(' ') || undefined;
---

<div class={cn('ds-field ds-field--radio', error && 'ds-field--error', className)}>
  <label class="ds-radio" for={id}>
    <input
      type="radio"
      id={id}
      name={groupName}
      value={value}
      class="ds-radio__input"
      required={required}
      checked={checked}
      disabled={disabled}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={describedBy}
    />
    <span class="ds-radio__label">{label}</span>
  </label>
  {hint && <p class="ds-field__hint" id={`${id}-hint`}>{hint}</p>}
  {error && (
    <p class="ds-field__error" id={`${id}-error`} role="alert">
      {error}
    </p>
  )}
</div>
