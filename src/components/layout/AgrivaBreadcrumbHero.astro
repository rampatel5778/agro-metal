---
/**
 * Agriva inner-page breadcrumb hero — breadcrumb-wrapper from about-2.html
 * Desktop: photo masked with breadcrumb.png cutout (mint title shape)
 * Mobile: full-bleed top-image photo + white title
 */
import type { AgrivaBreadcrumbHeroProps } from '@types/components/layout.js';

const {
  title,
  breadcrumbs = [],
  backgroundImageSrc = '/assets/img/home-3/about-1.jpg',
  topImageSrc = '/assets/img/home-3/about-1.jpg',
  shapeMaskSrc = '/assets/img/breadcrumb.png',
  class: className = '',
} = Astro.props as AgrivaBreadcrumbHeroProps;
---

<div
  class:list={['breadcrumb-wrapper', 'bg-cover', className]}
  style={`--breadcrumb-photo: url('${backgroundImageSrc}'); --breadcrumb-shape-mask: url('${shapeMaskSrc}');`}
>
  <div class="breadcrumb-photo" aria-hidden="true" />
  <div class="top-image">
    <img src={topImageSrc} alt="" loading="eager" decoding="async" />
  </div>
  <div class="container">
    <div class="page-heading">
      <div class="breadcrumb-sub-title">
        <h1 class="wow fadeInUp" data-wow-delay=".3s">{title}</h1>
      </div>
      {
        breadcrumbs.length > 0 && (
          <ul class="breadcrumb-items wow fadeInUp" data-wow-delay=".5s">
            {
              breadcrumbs.flatMap((crumb, index) => {
                const item = (
                  <li>
                    {crumb.href ? (
                      <a href={crumb.href}>
                        <i class="fa-solid fa-house" aria-hidden="true"></i> {crumb.label}
                      </a>
                    ) : (
                      crumb.label
                    )}
                  </li>
                );
                if (index < breadcrumbs.length - 1) {
                  return [item, <li>:</li>];
                }
                return [item];
              })
            }
          </ul>
        )
      }
    </div>
  </div>
</div>
