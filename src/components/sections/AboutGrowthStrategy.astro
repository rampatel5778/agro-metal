---
/**
 * About Growth Strategy — custom Strategy Rail
 * Agriva tokens: theme3 green, header type, wow fadeInUp, active fill hover
 */
import type { AboutGrowthStrategyProps } from '@types/components/content.js';

const {
  eyebrow = 'Growth Strategy',
  title,
  description,
  items,
} = Astro.props as AboutGrowthStrategyProps;
---

<section
  class="section-padding fix about-growth-strategy"
  aria-labelledby="about-growth-strategy-heading"
>
  <div class="container">
    <div class="section-title text-center about-growth-strategy__header">
      {eyebrow && <span class="sub-title-3">{eyebrow}</span>}
      <h2 id="about-growth-strategy-heading" class="text-anim">{title}</h2>
      {
        description && (
          <p class="about-growth-strategy__intro wow fadeInUp" data-wow-delay=".25s">
            {description}
          </p>
        )
      }
    </div>

    <div class="about-growth-strategy__rail" role="list">
      {
        items.map((item, index) => {
          const step = String(index + 1).padStart(2, '0');
          return (
            <article
              class:list={[
                'about-growth-strategy__step',
                'wow',
                'fadeInUp',
                index === 0 && 'active',
              ]}
              data-wow-delay={`${(0.2 + index * 0.1).toFixed(1)}s`}
              role="listitem"
              tabindex="0"
            >
              <div class="about-growth-strategy__marker" aria-hidden="true">
                <span class="about-growth-strategy__number">{step}</span>
                <span class="about-growth-strategy__dot" />
              </div>
              <div class="about-growth-strategy__card">
                <h3 class="about-growth-strategy__title">{item.title}</h3>
                <p class="about-growth-strategy__body">{item.description}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script src="@scripts/agriva-growth-strategy.ts"></script>
