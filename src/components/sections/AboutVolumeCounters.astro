---
/**
 * About page — intro + volume counters
 * Agriva about-2.html our-statistics-section / statistics-card
 * Image column removed; 6 cards in a full-width 3×2 grid
 * @see existing website/about-us.html section 2
 */
import type { AboutVolumeCountersProps } from '@types/components/content.js';

const { eyebrow, title, items } = Astro.props as AboutVolumeCountersProps;
---

<section
  class="our-statistics-section section-padding fix section-bg-3 about-statistics-section"
  aria-labelledby="about-volume-heading"
>
  <div class="container">
    <div class="our-statistics-wrapper">
      <div class="our-statistics-content">
        <div class="section-title mb-0 wow fadeInUp" data-wow-delay=".3s">
          {eyebrow && <span class="sub-title-3">{eyebrow}</span>}
          <h2 id="about-volume-heading" class="text-anim">{title}</h2>
        </div>

        <div class="about-statistics-grid">
          {
            items.map((item, index) => (
              <div
                class="statistics-card wow fadeInUp"
                data-wow-delay={`${(0.4 + index * 0.1).toFixed(1)}s`}
              >
                <h3>
                  {item.prefix}
                  <span class="count" data-count-value={item.value}>
                    {item.value}
                  </span>
                  {item.suffix}
                </h3>
                <p>
                  {item.heading}
                  <br />
                  {item.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script src="@scripts/agriva-counters.ts"></script>
