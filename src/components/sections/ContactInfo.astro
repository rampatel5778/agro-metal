---
/**
 * Contact info — Agriva contact-info-section
 * Left: eyebrow + headline + phone/email icons
 * Right: intro copy + address + Get direction
 */
import type { ContactInfoProps } from '@types/components/content.js';

const {
  id = 'contact-info',
  eyebrow = 'Get in Touch',
  title,
  description,
  phoneLabel = 'Phone',
  phone,
  phoneHref,
  faxLabel = 'Fax',
  fax,
  faxHref,
  emailLabel = 'Email',
  email,
  emailHref,
  addressLabel = 'Our address',
  addressLines,
  directionsLabel = 'Get direction',
  directionsHref,
  class: className = '',
} = Astro.props as ContactInfoProps;

const headingId = `${id}-heading`;
---

<section
  id={id}
  class:list={['contact-info-section', 'section-padding', 'fix', 'contact-info', className]}
  aria-labelledby={headingId}
>
  <div class="container">
    <div class="contact-info-wrapper">
      <div class="contact-info-left-content">
        <div class="section-title mb-0">
          {eyebrow && <span class="sub-title-3">{eyebrow}</span>}
          <h2 id={headingId} class="text-anim">{title}</h2>
        </div>

        <div class="info-icon-item">
          <div class="icon-item wow fadeInUp" data-wow-delay=".6s">
            <div class="icon">
              <img src="/assets/img/home-2/icon/10.svg" alt="" loading="lazy" decoding="async" />
            </div>
            <div class="cont">
              <span>{phoneLabel}</span>
              <h3>
                <a href={phoneHref}>{phone}</a>
              </h3>
              <p class="contact-info__fax">
                <span>{faxLabel}:</span>
                <a href={faxHref}>{fax}</a>
              </p>
            </div>
          </div>

          <div class="icon-item wow fadeInUp" data-wow-delay=".8s">
            <div class="icon">
              <img src="/assets/img/home-2/icon/11.svg" alt="" loading="lazy" decoding="async" />
            </div>
            <div class="cont">
              <span>{emailLabel}</span>
              <h3>
                <a href={emailHref}>{email}</a>
              </h3>
            </div>
          </div>
        </div>
      </div>

      <div class="info-right-content">
        <p class="wow fadeInUp" data-wow-delay=".35s">{description}</p>
        <div class="icon-item wow fadeInUp" data-wow-delay=".6s">
          <div class="icon">
            <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
          </div>
          <div class="cont">
            <span>{addressLabel}</span>
            <h3>
              <a href={directionsHref} target="_blank" rel="noopener noreferrer">
                {addressLines.map((line, index) => (
                  <>
                    {index > 0 && <br />}
                    {line}
                  </>
                ))}
              </a>
            </h3>
          </div>
        </div>
        <div class="contact-info__directions wow fadeInUp" data-wow-delay=".75s">
          <a
            href={directionsHref}
            class="theme-btn theme-btn-3"
            target="_blank"
            rel="noopener noreferrer"
          >
            {directionsLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
