---
/**
 * Home hero — full-viewport muted YouTube loop + bottom category bar
 * Simplified layout (no Agriva circular slider / prev-next controls)
 */
import type { HeroVideoProps } from '@types/components/content.js';

const {
  youtubeId,
  eyebrow,
  title,
  description,
  primaryCta,
  secondaryCta,
  bottomBar,
  videoTitle = 'Background video',
  iconSrc = '/assets/img/home-2/icon/03.svg',
} = Astro.props as HeroVideoProps;

const showOverlayCopy = Boolean(eyebrow || title || description || primaryCta || secondaryCta);
---

<section
  class="home-hero"
  data-hero-video
  aria-label={title ? undefined : 'Home hero'}
  aria-labelledby={title ? 'hero-heading' : undefined}
>
  <div class="home-hero__media" data-hero-video-bg aria-hidden="true">
    <iframe
      data-hero-iframe
      data-youtube-id={youtubeId}
      title={videoTitle}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      loading="eager"
      tabindex="-1"
    ></iframe>
  </div>

  <div class="home-hero__shade" aria-hidden="true"></div>

  {
    showOverlayCopy && (
      <div class="home-hero__content">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-9">
              <div class="home-hero__copy">
                {iconSrc && (
                  <div class="home-hero__icon">
                    <img src={iconSrc} alt="" />
                  </div>
                )}
                {eyebrow && <span class="home-hero__eyebrow">{eyebrow}</span>}
                {title && (
                  <h1 id="hero-heading" class="home-hero__title" set:html={title} />
                )}
                {description && <p class="home-hero__desc">{description}</p>}
                {(primaryCta || secondaryCta) && (
                  <div class="home-hero__actions">
                    {primaryCta && (
                      <a href={primaryCta.href} class="theme-btn-2">
                        {primaryCta.label}
                      </a>
                    )}
                    {secondaryCta && (
                      <a href={secondaryCta.href} class="theme-btn-2">
                        {secondaryCta.label}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    )
  }

  {
    bottomBar && (
      <div class="hero-border-item">
        <div class="hero-bottom-item">
          <h2>{bottomBar.heading}</h2>
          <div class="hero-list">
            {
              bottomBar.items.map((item) => (
                <span>
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                  {item}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    )
  }
</section>

<script src="@scripts/hero-video.ts"></script>
