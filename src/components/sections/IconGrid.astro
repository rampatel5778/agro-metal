---
/**
 * IconGrid — icon + label grid
 * @example
 * <IconGrid items={[{ icon: 'wheat', label: 'Grains' }]} columns={3} />
 */
import type { IconGridProps } from '@types/components/business.js';
import { cn } from '@utils/classNames.js';
import Icon from '@components/ui/Icon.astro';
import Link from '@components/ui/Link.astro';

const {
  items,
  columns = 3,
  class: className = '',
  ariaLabel = 'Icon grid',
} = Astro.props as IconGridProps;

const colClass = `ds-grid--${columns}` as const;
---

<ul class={cn('ds-grid', colClass, className)} aria-label={ariaLabel}>
  {
    items.map((item) => (
      <li class="ds-card ds-card--feature">
        {
          item.href ? (
            <Link href={item.href} class="ds-stack ds-stack--sm text-center">
              <Icon name={item.icon} size="2x" label={item.label} />
              <span class="ds-card__title">{item.label}</span>
            </Link>
          ) : (
            <div class="ds-stack ds-stack--sm text-center">
              <div class="ds-card__icon">
                <Icon name={item.icon} size="lg" decorative />
              </div>
              <span class="ds-card__title">{item.label}</span>
            </div>
          )
        }
      </li>
    ))
  }
</ul>
