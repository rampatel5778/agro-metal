---
/**
 * IndustryCards — industry served grid (typically 6 columns on desktop)
 * @example
 * <IndustryCards items={industries} columns={6} />
 */
import type { IndustryCardsProps } from '@types/components/business.js';
import { cn } from '@utils/classNames.js';
import Card from '@components/ui/Card.astro';
import Image from '@components/ui/Image.astro';
import Icon from '@components/ui/Icon.astro';

const {
  items,
  columns = 6,
  class: className = '',
  ariaLabel = 'Industries served',
} = Astro.props as IndustryCardsProps;

const colClass = columns <= 4 ? `ds-grid--${columns}` : 'ds-grid--4 ds-grid--industry-6';
---

<ul class={cn('ds-grid', colClass, className)} aria-label={ariaLabel}>
  {
    items.map((item) => (
      <li>
        <Card variant="feature" href={item.href} class="ds-card--lift h-full">
          {
            item.image ? (
              <Image
                src={item.image.src}
                alt={item.image.alt}
                width={item.image.width}
                height={item.image.height}
                aspect="square"
              />
            ) : item.icon ? (
              <div class="ds-card__icon">
                <Icon name={item.icon} size="lg" decorative />
              </div>
            ) : null
          }
          <div class="ds-card__body">
            <h3 class="ds-card__title">{item.title}</h3>
            {item.description && <p class="ds-card__text">{item.description}</p>}
          </div>
        </Card>
      </li>
    ))
  }
</ul>
