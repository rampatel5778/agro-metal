---
/**
 * IntroText — intro section with optional CTA
 * @example
 * <IntroText heading="Welcome" body="..." cta={{ label: 'Learn more', href: '/about-us/' }} />
 */
import type { IntroTextProps } from '@types/components/content.js';
import { cn } from '@utils/classNames.js';
import Button from '@components/ui/Button.astro';

const {
  heading,
  body,
  cta,
  align = 'left',
  class: className = '',
} = Astro.props as IntroTextProps;

const paragraphs = Array.isArray(body) ? body : [body];
---

<div class={cn('ds-stack ds-stack--lg', align === 'center' && 'text-center', className)}>
  {heading && <h2 class="ds-h2">{heading}</h2>}
  <div class="ds-stack">
    {paragraphs.map((p) => <p class="ds-body">{p}</p>)}
  </div>
  {
    cta && (
      <Button variant="primary" href={cta.href} external={cta.external}>
        {cta.label}
      </Button>
    )
  }
</div>
