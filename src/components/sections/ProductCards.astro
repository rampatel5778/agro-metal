---
/**
 * ProductCards — home page category cards
 * @example
 * <ProductCards items={products} columns={3} />
 */
import type { ProductCardsProps } from '@types/components/business.js';
import { cn } from '@utils/classNames.js';
import Card from '@components/ui/Card.astro';
import Image from '@components/ui/Image.astro';
import Tag from '@components/ui/Tag.astro';
import Button from '@components/ui/Button.astro';

const {
  items,
  columns = 3,
  class: className = '',
  ariaLabel = 'Products',
} = Astro.props as ProductCardsProps;

const colClass = `ds-grid--${columns}` as const;
---

<ul class={cn('ds-grid', colClass, className)} aria-label={ariaLabel}>
  {
    items.map((item) => (
      <li>
        <Card variant="product" href={item.href} class="ds-card--lift h-full">
          {
            item.image && (
              <div class="ds-card__media">
                {item.category && <Tag text={item.category} class="ds-card__tag" />}
                <Image
                  src={item.image.src}
                  alt={item.image.alt}
                  width={item.image.width}
                  height={item.image.height}
                  aspect="portrait"
                />
              </div>
            )
          }
          <div class="ds-card__body">
            <h3 class="ds-card__title">{item.title}</h3>
            {item.description && <p class="ds-card__text">{item.description}</p>}
            {
              item.cta && (
                <Button variant="link" href={item.cta.href}>
                  {item.cta.label}
                </Button>
              )
            }
          </div>
        </Card>
      </li>
    ))
  }
</ul>
