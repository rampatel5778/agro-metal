---
/**
 * Products Range Intro — centered Agriva section-title
 * Eyebrow + title + supporting copy (cards stay separate below).
 */
import type { ProductsRangeIntroProps } from '@types/components/content.js';

const {
  eyebrow = 'What We Supply',
  title,
  description,
  class: className = '',
} = Astro.props as ProductsRangeIntroProps;
---

<section
  class:list={['section-padding', 'fix', 'products-range-intro', className]}
  aria-labelledby="products-range-heading"
>
  <div class="container">
    <div class="section-title text-center products-range-intro__header">
      {eyebrow && <span class="sub-title-3">{eyebrow}</span>}
      <h2 id="products-range-heading" class="text-anim">
        {title}
      </h2>
      <p class="products-range-intro__text wow fadeInUp" data-wow-delay=".25s">
        {description}
      </p>
    </div>
  </div>
</section>
