---
/**
 * Sustainability Looking Ahead — Agriva about-us-two-section (simplified)
 * Image left | title + intro + checklist + closing paragraph
 */
import type { SustainabilityLookingAheadProps } from '@types/components/content.js';

const {
  id = 'sustainability-looking-ahead',
  title,
  description,
  goals,
  closing,
  imageSrc,
  imageAlt,
  class: className = '',
} = Astro.props as SustainabilityLookingAheadProps;

const headingId = `${id}-heading`;
---

<section
  id={id}
  class:list={[
    'about-us-two-section',
    'section-padding',
    'fix',
    'sustainability-looking-ahead',
    className,
  ]}
  aria-labelledby={headingId}
>
  <div class="container">
    <div class="about-us-two-wrapper">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <div class="about-us-image sustainability-looking-ahead__image wow img-custom-anim-left">
            <img
              src={imageSrc}
              alt={imageAlt}
              loading="lazy"
              decoding="async"
              width="1200"
              height="800"
            />
          </div>
        </div>

        <div class="col-lg-6">
          <div class="about-us-content sustainability-looking-ahead__content">
            <div class="section-title mb-0">
              <h2 id={headingId} class="text-anim">{title}</h2>
            </div>

            <p class="text sustainability-looking-ahead__intro wow fadeInUp" data-wow-delay=".25s">
              {description}
            </p>

            <ul class="list sustainability-looking-ahead__list wow fadeInUp" data-wow-delay=".35s">
              {
                goals.map((goal) => (
                  <li>
                    <i class="fa-solid fa-circle-check" aria-hidden="true" />
                    {goal}
                  </li>
                ))
              }
            </ul>

            <p class="text sustainability-looking-ahead__closing wow fadeInUp" data-wow-delay=".45s">
              {closing}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
