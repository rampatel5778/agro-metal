---
/**
 * TimelineVertical — vertical milestone timeline
 * @example
 * <TimelineVertical items={milestones} heading="Our History" />
 */
import type { TimelineVerticalProps } from '@types/components/content.js';
import { cn } from '@utils/classNames.js';
import SectionTitle from '@components/layout/SectionTitle.astro';
import Image from '@components/ui/Image.astro';

const { items, heading, class: className = '' } = Astro.props as TimelineVerticalProps;
---

<div class={cn('ds-timeline ds-timeline--vertical', className)}>
  {heading && <SectionTitle title={heading} />}
  <ol class="ds-timeline__list">
    {
      items.map((item) => (
        <li class="ds-timeline__item ds-card ds-card--timeline">
          {item.year && <span class="ds-timeline__year">{item.year}</span>}
          <h3 class="ds-card__title">{item.title}</h3>
          {item.body && <p class="ds-card__text">{item.body}</p>}
          {
            item.image && (
              <Image
                src={item.image.src}
                alt={item.image.alt}
                width={item.image.width}
                height={item.image.height}
                aspect="landscape"
                rounded="lg"
              />
            )
          }
        </li>
      ))
    }
  </ol>
</div>
