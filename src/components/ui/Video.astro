---
/**
 * Video — native HTML5 video element
 * @example
 * <Video src="/videos/hero.mp4" poster="/images/poster.jpg" autoplay muted loop />
 */
import type { VideoProps } from '@types/components/ui.js';
import { cn } from '@utils/classNames.js';

const {
  src,
  poster,
  autoplay = false,
  loop = false,
  muted = false,
  controls = true,
  class: className = '',
  ariaLabel,
} = Astro.props as VideoProps;
---

<video
  class={cn('ds-video', className)}
  src={src}
  poster={poster}
  autoplay={autoplay}
  loop={loop}
  muted={muted}
  controls={controls}
  playsinline
  aria-label={ariaLabel}
>
  <slot />
</video>
