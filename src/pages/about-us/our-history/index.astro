---
/**
 * Our History — /about-us/our-history/
 * Reuses the Home vertical timeline section as-is
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import AgrivaBreadcrumbHero from '@components/layout/AgrivaBreadcrumbHero.astro';
import HomeTimeline from '@components/sections/HomeTimeline.astro';
import { getSiteLayout } from '@lib/layout/getSiteLayout.js';
import {
  ourHistoryHero,
  ourHistoryTimeline,
} from '@data/pages/our-history.js';

const layout = getSiteLayout(Astro.url.pathname);
---

<BaseLayout {...layout} bodyClass="page-about page-our-history">
  <AgrivaBreadcrumbHero {...ourHistoryHero} />
  <HomeTimeline {...ourHistoryTimeline} />
</BaseLayout>

<script is:inline src="/assets/js/gsap.min.js"></script>
<script is:inline src="/assets/js/ScrollTrigger.min.js"></script>
<script is:inline src="/assets/js/wow.min.js"></script>
<script>
  import '@scripts/home-timeline.ts';
</script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof WOW !== 'undefined') {
      new WOW({ live: false, mobile: true }).init();
    }
  });
</script>
