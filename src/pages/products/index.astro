---
/**
 * Products hub — /products/
 * 1. Agriva breadcrumb hero
 * 2. Our Product Range intro + home product cards (as-is)
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import AgrivaBreadcrumbHero from '@components/layout/AgrivaBreadcrumbHero.astro';
import ProductsRangeIntro from '@components/sections/ProductsRangeIntro.astro';
import HomeProductCards from '@components/sections/HomeProductCards.astro';
import HomePageScripts from '@components/layout/HomePageScripts.astro';
import { getSiteLayout } from '@lib/layout/getSiteLayout.js';
import { productsHero, productsRangeIntro } from '@data/pages/products.js';
import { homeProductCards } from '@data/pages/home.js';

const layout = getSiteLayout(Astro.url.pathname);
---

<BaseLayout {...layout} bodyClass="page-products">
  <AgrivaBreadcrumbHero {...productsHero} />
  <ProductsRangeIntro {...productsRangeIntro} />
  <HomeProductCards {...homeProductCards} />
  <HomePageScripts slot="scripts" />
</BaseLayout>
