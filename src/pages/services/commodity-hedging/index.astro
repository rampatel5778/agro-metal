---
/**
 * Commodity Hedging — /services/commodity-hedging/
 * 1. Agriva breadcrumb hero
 * 2. Intro + Benefits — about-section-4
 * 3. Why Choose Agro Metal? — 2×2 + image
 * 4. Closing video CTA — drone-video-section
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import AgrivaBreadcrumbHero from '@components/layout/AgrivaBreadcrumbHero.astro';
import ServiceDetailIntro from '@components/sections/ServiceDetailIntro.astro';
import ServiceWhyChoose from '@components/sections/ServiceWhyChoose.astro';
import ProductClosingCta from '@components/sections/ProductClosingCta.astro';
import { getSiteLayout } from '@lib/layout/getSiteLayout.js';
import {
  commodityHedgingHero,
  commodityHedgingIntro,
  commodityHedgingWhyChoose,
  commodityHedgingClosingCta,
} from '@data/pages/commodity-hedging.js';

const layout = getSiteLayout(Astro.url.pathname);
---

<BaseLayout {...layout} bodyClass="page-services page-service-detail page-commodity-hedging">
  <AgrivaBreadcrumbHero {...commodityHedgingHero} />
  <ServiceDetailIntro {...commodityHedgingIntro} />
  <ServiceWhyChoose {...commodityHedgingWhyChoose} />
  <ProductClosingCta {...commodityHedgingClosingCta} />
</BaseLayout>

<script is:inline src="/assets/js/wow.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof WOW !== 'undefined') {
      new WOW({ live: false, mobile: true }).init();
    }
  });
</script>
