---
/**
 * Sustainability — /sustainability/
 * 1. Agriva breadcrumb hero
 * 2. ESG Commitment intro — about-section-3
 * 3. ESG pillars — pricing-section-2
 * 4. Looking Ahead — about-us-two-section
 * 5. Closing video CTA — drone-video-section
 */
import BaseLayout from '@components/layout/BaseLayout.astro';
import AgrivaBreadcrumbHero from '@components/layout/AgrivaBreadcrumbHero.astro';
import SustainabilityEsgIntro from '@components/sections/SustainabilityEsgIntro.astro';
import SustainabilityEsgPillars from '@components/sections/SustainabilityEsgPillars.astro';
import SustainabilityLookingAhead from '@components/sections/SustainabilityLookingAhead.astro';
import ProductClosingCta from '@components/sections/ProductClosingCta.astro';
import { getSiteLayout } from '@lib/layout/getSiteLayout.js';
import {
  sustainabilityHero,
  sustainabilityEsgIntro,
  sustainabilityEsgPillars,
  sustainabilityLookingAhead,
  sustainabilityClosingCta,
} from '@data/pages/sustainability.js';

const layout = getSiteLayout(Astro.url.pathname);
---

<BaseLayout {...layout} bodyClass="page-sustainability">
  <AgrivaBreadcrumbHero {...sustainabilityHero} />
  <SustainabilityEsgIntro {...sustainabilityEsgIntro} />
  <SustainabilityEsgPillars {...sustainabilityEsgPillars} />
  <SustainabilityLookingAhead {...sustainabilityLookingAhead} />
  <ProductClosingCta {...sustainabilityClosingCta} />
</BaseLayout>

<script is:inline src="/assets/js/wow.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof WOW !== 'undefined') {
      new WOW({ live: false, mobile: true }).init();
    }
  });
</script>

<script is:inline src="/assets/js/wow.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof WOW !== 'undefined') {
      new WOW({ live: false, mobile: true }).init();
    }
  });
</script>
